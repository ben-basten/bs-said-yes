{
  "name": "nuxt-starter",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm generate:types && nuxt build",
    "dev": "nuxt dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate": "nuxt generate",
    "generate:types": "graphql-codegen --require dotenv/config --config codegen.ts",
    "generate:types:watch": "pnpm generate:types --watch",
    "lint": "eslint .",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env ./scripts/seed.ts",
    "db:seed:prd": "tsx --env-file=.env ./scripts/seed.ts guests.csv",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/vite": "^4.3.1",
    "contentful-rich-text-vue-renderer": "^3.2.1",
    "drizzle-orm": "^0.45.2",
    "gqlmin": "^0.3.2",
    "graphql-request": "^7.4.0",
    "gsap": "^3.15.0",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "pinia": "^3.0.4",
    "reka-ui": "^2.10.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@contentful/rich-text-types": "^17.2.7",
    "@graphql-codegen/cli": "^6.3.1",
    "@nuxt/eslint": "^1.16.0",
    "@parcel/watcher": "^2.5.6",
    "@types/node": "^24.13.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "fast-csv": "^5.0.7",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.3.5"
  },
  "nano-staged": {
    "*.{js,mjs,jsx,ts,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.1.3"
}
